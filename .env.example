# Robot Configuration
ROBOT_MODEL=ur5

# ROS Configuration
ROS_DOMAIN_ID=0
GZ_PARTITION=sim

# Ports
ROSBRIDGE_PORT=9090
VNC_PORT=8080
CLIENT_PORT=5173

# AI Assistant (optional) — get a free key at https://aistudio.google.com/apikey
VITE_GEMINI_API_KEY=

# Ollama (optional) — use with: docker compose --profile ollama up
# Then pull a model: docker exec <ollama-container> ollama pull llama3.1
OLLAMA_MODEL=llama3.1
OLLAMA_PORT=11434
