{
  "id": "ur5",
  "name": "UR5 Robot Arm",
  "version": "1.0.0",
  "description": "Position control for the UR5 robotic arm joints via ROS",

  "ai": {
    "subcategory_hints": {
      "UR5 Arm": "Use Move Single Joint to control individual UR5 joints by publishing position commands."
    }
  },

  "blocks": [
    {
      "type": "ur5_move_single_joint",
      "display_name": "Move Single Joint",
      "ai_description": "Move one UR5 joint directly to a position (radians) using position control.",
      "ai_example": "{ type: \"ur5_move_single_joint\", joint_topic: \"/ur5/shoulder_pan/cmd\", position: 1.57 }",
      "definition": {
        "message0": "Move UR5 %1 to position (radians) %2",
        "args0": [
          {
            "type": "field_dropdown",
            "name": "JOINT_TOPIC",
            "options": [
              ["Shoulder Pan", "/ur5/shoulder_pan/cmd"],
              ["Shoulder Lift", "/ur5/shoulder_lift/cmd"],
              ["Elbow", "/ur5/elbow/cmd"],
              ["Wrist 1", "/ur5/wrist_1/cmd"],
              ["Wrist 2", "/ur5/wrist_2/cmd"],
              ["Wrist 3", "/ur5/wrist_3/cmd"]
            ]
          },
          { "type": "input_value", "name": "POSITION", "check": "Number" }
        ],
        "previousStatement": null,
        "nextStatement": null,
        "colour": 230,
        "tooltip": "Move a single UR5 joint directly using Position Control"
      },
      "generator": {
        "type": "statement",
        "template": "{\n  var topic = new ROSLIB.Topic({ ros: ros, name: '{{$JOINT_TOPIC}}', messageType: 'std_msgs/msg/Float64' });\n  var msg = new ROSLIB.Message({ data: {{POSITION}} });\n  topic.publish(msg);\n  console.log('Published {{$JOINT_TOPIC}}: ' + {{POSITION}});\n}\n",
        "inputs": {
          "POSITION": { "order": "ATOMIC", "default": "0" }
        }
      }
    }
  ],

  "reset": [
    { "topic": "/ur5/shoulder_pan/cmd", "type": "std_msgs/msg/Float64", "data": { "data": 0 } },
    { "topic": "/ur5/shoulder_lift/cmd", "type": "std_msgs/msg/Float64", "data": { "data": 0 } },
    { "topic": "/ur5/elbow/cmd", "type": "std_msgs/msg/Float64", "data": { "data": 0 } },
    { "topic": "/ur5/wrist_1/cmd", "type": "std_msgs/msg/Float64", "data": { "data": 0 } },
    { "topic": "/ur5/wrist_2/cmd", "type": "std_msgs/msg/Float64", "data": { "data": 0 } },
    { "topic": "/ur5/wrist_3/cmd", "type": "std_msgs/msg/Float64", "data": { "data": 0 } }
  ],

  "category": {
    "name": "UR5 Arm",
    "colour": 230,
    "blocks": [
      { "type": "ur5_move_single_joint" }
    ]
  }
}
